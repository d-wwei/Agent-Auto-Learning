{
  "name": "auto-learning-mcp",
  "version": "0.3.0",
  "description": "MCP server for agent self-learning — memory, skills, and session review",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "auto-learning-mcp": "dist/index.js",
    "auto-learning-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "setup": "node dist/setup.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "clean": "rm -rf dist",
    "dashboard": "node dist/dashboard.js",
    "dashboard:html": "node dist/dashboard.js --html"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
